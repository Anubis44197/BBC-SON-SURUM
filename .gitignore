# BBC MASTER .gitignore - v8.3 Clean

# ─── Python ───
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
.tox/

# ─── Tests & Coverage ───
tests/
.coverage
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
htmlcov/
.ruff_cache/

# ─── Build Artifacts ───
*.egg-info/
dist/
build/

# ─── IDE & Editor ───
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─── BBC Runtime Files (proje icinde olusturulan, git'e gitmez) ───
.bbc/
.antigravity/
.continue/
.windsurf/
.github/copilot-instructions.md

# ─── BBC Eski / Legacy dosyalar ───
BBC_CONTEXT.md
BBC_INSTRUCTIONS.md
BBC_README.md
ai-context.json
bbc_context.json
bbc_rules.md

# ─── Log & Gecici Dosyalar ───
*.log
firebase-debug.log

# ─── Test Klasoru (CI icin gerekli, git'te tutulur) ───
# tests/ klasoru GitHub Actions CI tarafindan kullanilir

# --- BBC Isolation Shield (No-Trace) ---
.antigravity/rules.md
.bbc/BBC_INSTRUCTIONS.md
.bbc/bbc_context.md
.bbc/bbc_rules.md
.continue/config.json
