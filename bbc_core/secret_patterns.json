{
  "_meta": {
    "version": "1.0.0",
    "description": "BBC Secret Signal Detection - Pattern Definitions",
    "license_note": "Patterns are original BBC implementations inspired by common secret-detection heuristics. Not copied from any external project.",
    "categories": ["cloud", "auth", "db", "crypto", "pii"]
  },
  "patterns": [
    {
      "id": "aws_access_key",
      "category": "cloud",
      "label": "AWS Access Key ID",
      "regex": "(?:^|[^A-Za-z0-9/+=])(?:AKIA)[A-Z0-9]{16}(?:[^A-Za-z0-9/+=]|$)",
      "severity": "high",
      "confidence": 0.95,
      "false_positive_hints": ["example", "sample", "test", "dummy", "placeholder", "AKIAIOSFODNN7EXAMPLE"]
    },
    {
      "id": "aws_secret_key",
      "category": "cloud",
      "label": "AWS Secret Access Key",
      "regex": "(?i)(?:aws_secret_access_key|aws_secret_key|secret_key)\\s*[=:]\\s*['\"]?([A-Za-z0-9/+=]{40})['\"]?",
      "severity": "critical",
      "confidence": 0.90,
      "false_positive_hints": ["example", "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY", "test", "dummy"]
    },
    {
      "id": "generic_api_key",
      "category": "auth",
      "label": "Generic API Key Assignment",
      "regex": "(?i)(?:api[_-]?key|apikey|api[_-]?secret|api[_-]?token)\\s*[=:]\\s*['\"]([a-zA-Z0-9_\\-]{20,})['\"]",
      "severity": "high",
      "confidence": 0.75,
      "false_positive_hints": ["example", "your_api_key_here", "test", "placeholder", "xxx", "TODO"]
    },
    {
      "id": "generic_secret",
      "category": "auth",
      "label": "Generic Secret Assignment",
      "regex": "(?i)(?:secret|password|passwd|pwd|token|credential)\\s*[=:]\\s*['\"]([^'\"\\s]{8,})['\"]",
      "severity": "high",
      "confidence": 0.65,
      "false_positive_hints": ["example", "your_secret_here", "test", "placeholder", "changeme", "password123", "********"]
    },
    {
      "id": "private_key_block",
      "category": "crypto",
      "label": "Private Key (PEM Block)",
      "regex": "-----BEGIN (?:RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----",
      "severity": "critical",
      "confidence": 0.99,
      "false_positive_hints": []
    },
    {
      "id": "github_token",
      "category": "auth",
      "label": "GitHub Personal Access Token",
      "regex": "(?:^|[^A-Za-z0-9])(?:ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{36,}",
      "severity": "critical",
      "confidence": 0.97,
      "false_positive_hints": ["example"]
    },
    {
      "id": "jwt_token",
      "category": "auth",
      "label": "JSON Web Token",
      "regex": "eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_\\-]{10,}",
      "severity": "high",
      "confidence": 0.85,
      "false_positive_hints": ["example", "test"]
    },
    {
      "id": "db_connection_string",
      "category": "db",
      "label": "Database Connection String with Credentials",
      "regex": "(?i)(?:mongodb(?:\\+srv)?|postgres(?:ql)?|mysql|mssql|redis|amqp)://[^\\s'\"]+:[^\\s@'\"]+@[^\\s'\"]+",
      "severity": "critical",
      "confidence": 0.92,
      "false_positive_hints": ["localhost", "127.0.0.1", "example.com", "user:password@"]
    },
    {
      "id": "slack_webhook",
      "category": "cloud",
      "label": "Slack Webhook URL",
      "regex": "https://hooks\\.slack\\.com/services/T[A-Z0-9]{8,}/B[A-Z0-9]{8,}/[A-Za-z0-9]{20,}",
      "severity": "high",
      "confidence": 0.95,
      "false_positive_hints": ["example"]
    },
    {
      "id": "azure_storage_key",
      "category": "cloud",
      "label": "Azure Storage Account Key",
      "regex": "(?i)(?:AccountKey|account_key|storage_key)\\s*[=:]\\s*['\"]?([A-Za-z0-9+/]{86}==)['\"]?",
      "severity": "critical",
      "confidence": 0.90,
      "false_positive_hints": ["example", "Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw=="]
    },
    {
      "id": "gcp_service_account",
      "category": "cloud",
      "label": "GCP Service Account Key Fragment",
      "regex": "\"type\"\\s*:\\s*\"service_account\"",
      "severity": "high",
      "confidence": 0.80,
      "false_positive_hints": ["example", "test"]
    },
    {
      "id": "email_address",
      "category": "pii",
      "label": "Email Address (Potential PII)",
      "regex": "[a-zA-Z0-9._%+\\-]{3,}@[a-zA-Z0-9.\\-]+\\.[a-zA-Z]{2,}",
      "severity": "low",
      "confidence": 0.50,
      "false_positive_hints": ["example.com", "test.com", "noreply", "placeholder", "@example", "user@domain.com"]
    }
  ]
}
